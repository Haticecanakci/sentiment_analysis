# PostgreSQL bağlantı dizesi (Prisma tarafından kullanılır)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_reviews"

# Google Gemini API anahtarı (https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Kullanılacak Gemini modeli (varsayılan: gemini-2.0-flash)
GEMINI_MODEL="gemini-2.0-flash"

# CSV import sırasında eşzamanlı Gemini çağrısı üst sınırı (asyncio.Semaphore)
GEMINI_MAX_CONCURRENCY=5
